ght!\");\n  }\n\n  body.addEventListener(\"touchstart\", (e) => {\n    touchstartX = e.changedTouches[0].screenX;\n  });\n\n  body.addEventListener(\"touchend\", (e) => {\n    touchendX = e.changedTouches[0].screenX;\n    handleGesture();\n  });\n})();\n",[201],{"type":19,"tag":59,"props":202,"children":203},{"__ignoreMap":8},[204],{"type":26,"value":199},{"type":19,"tag":64,"props":206,"children":207},{"id":66},[208],{"type":26,"value":69},{"type":19,"tag":71,"props":210,"children":211},{},[212],{"type":19,"tag":75,"props":213,"children":214},{},[215],{"type":19,"tag":79,"props":216,"children":219},{"href":217,"rel":218},"https://stackoverflow.com/questions/2264072/detect-a-finger-swipe-through-javascript-on-the-iphone-and-android",[83],[220],{"type":26,"value":217},{"title":8,"searchDepth":96,"depth":96,"links":222},[223],{"id":66,"depth":96,"text":69},"content:snippets:detect-horizontal-swipe.md","snippets/detect-horizontal-swipe.md","snippets/detect-horizontal-swipe",1772401384682]