:34,"value":87},"Log in to Webtrends Optimize.",{"type":21,"tag":41,"props":89,"children":90},{},[91],{"type":34,"value":92},"Go to Dashboard.",{"type":21,"tag":41,"props":94,"children":95},{},[96],{"type":34,"value":97},"Click on the desired experiment from the list.",{"type":21,"tag":41,"props":99,"children":100},{},[101],{"type":34,"value":102},"Move the content slider to the 4th item.",{"type":21,"tag":41,"props":104,"children":105},{},[106],{"type":34,"value":107},"Now you'll see the Experiment Preview section like the below screenshot.",{"type":21,"tag":41,"props":109,"children":110},{},[111],{"type":34,"value":112},"Copy desired variation link by clicking on the clipboard icon and preview it.",{"type":21,"tag":41,"props":114,"children":115},{},[116],{"type":34,"value":117},"That's how to preview experiments using Webtrends default preview links.",{"type":21,"tag":119,"props":120,"children":121},"p",{},[122],{"type":21,"tag":123,"props":124,"children":127},"img",{"alt":125,"src":126},"image","https://dev-to-uploads.s3.amazonaws.com/uploads/articles/ijpwkbh23l63ahlo62vc.png",[],{"type":21,"tag":29,"props":129,"children":131},{"id":130},"preview-experiments-using-force-experiment-widget",[132],{"type":34,"value":133},"Preview experiments using Force Experiment Widget",{"type":21,"tag":80,"props":135,"children":136},{},[137,150,162,167,178],{"type":21,"tag":41,"props":138,"children":139},{},[140,142],{"type":34,"value":141},"Go to ",{"type":21,"tag":143,"props":144,"children":148},"a",{"href":145,"rel":146},"https://c.webtrends-optimize.com/acs/fxp/install.html",[147],"nofollow",[149],{"type":34,"value":145},{"type":21,"tag":41,"props":151,"children":152},{},[153,155,160],{"type":34,"value":154},"Drag and drop the ",{"type":21,"tag":47,"props":156,"children":157},{},[158],{"type":34,"value":159},"WTO Force Experiment",{"type":34,"value":161}," button to your bookmarks bar.",{"type":21,"tag":41,"props":163,"children":164},{},[165],{"type":34,"value":166},"Visit the test page (target page where the variation will run).",{"type":21,"tag":41,"props":168,"children":169},{},[170,172,176],{"type":34,"value":171},"Click/tap on the ",{"type":21,"tag":47,"props":173,"children":174},{},[175],{"type":34,"value":159},{"type":34,"value":177}," bookmarklet.",{"type":21,"tag":41,"props":179,"children":180},{},[181],{"type":34,"value":182},"It will open a popup from where you will be able to select your desired variation.",{"type":21,"tag":119,"props":184,"children":185},{},[186,192],{"type":21,"tag":187,"props":188,"children":189},"em",{},[190],{"type":34,"value":191},"NOTE:",{"type":34,"value":193}," You can paste the following code to the console to open the Force Experiment Widget.",{"type":21,"tag":195,"props":196,"children":201},"pre",{"className":197,"code":199,"filename":200,"language":200,"meta":8},[198],"language-js","javascript:function FXP(){var a=\"https://c.webtrends-optimize.com/acs/fxp\",b=\"_wto.fxp\";window[b+\":cfg\"]={debug:!1,insTS:\"1627290085077\",baseURL:a,instRef:\"PROD\"};var c=document.getElementById(b);if(c)window.WTOExp&&WTOExp.Run(\"bookmarklet\");else{c=document.createElement(\"script\"),c.id=b,c.src=\"https://c.webtrends-optimize.com/acs/fxp/wto_fxp.min.js\";var d=document.body;c.onerror=function(){d.removeChild(c),alert(\"Error while loading WTO ForceExp. Try again.\")},d&&d.appendChild(c)}}FXP();\n","js",[202],{"type":21,"tag":203,"props":204,"children":205},"code",{"__ignoreMap":8},[206],{"type":34,"value":199},{"type":21,"tag":29,"props":208,"children":210},{"id":209},"preview-experiments-using-the-query-parameter",[211],{"type":34,"value":212},"Preview experiments using the query parameter",{"type":21,"tag":37,"props":214,"children":215},{},[216],{"type":21,"tag":41,"props":217,"children":218},{},[219,221,225],{"type":34,"value":220},"Add ",{"type":21,"tag":47,"props":222,"children":223},{},[224],{"type":34,"value":72},{"type":34,"value":226}," query parameter at the end of target URL to view the variation.",{"type":21,"tag":119,"props":228,"children":229},{},[230],{"type":34,"value":231},"It will show the variation randomly, maybe variation 1, variation 2, or even control. If you have multiple variations and you want to view a specific variation all the time, then you have to set that up.",{"type":21,"tag":119,"props":233,"children":234},{},[235],{"type":34,"value":236},"To do that, go to the dashboard, click on the desired experiment to open the content slider, and find the display dropdown at the bottom right corner of the 1st slide. See the screenshot below.",{"type":21,"tag":119,"props":238,"children":239},{},[240],{"type":21,"tag":123,"props":241,"children":243},{"alt":125,"src":242},"https://dev-to-uploads.s3.amazonaws.com/uploads/articles/61u247yv5weth93x502i.png",[],{"type":21,"tag":119,"props":245,"children":246},{},[247],{"type":34,"value":248},"Clicking on that display select dropdown, a modal popup will open like the following screenshot.",{"type":21,"tag":119,"props":250,"children":251},{},[252],{"type":21,"tag":123,"props":253,"children":255},{"alt":125,"src":254},"https://dev-to-uploads.s3.amazonaws.com/uploads/articles/tokdzz7zjl3icg4x13yc.png",[],{"type":21,"tag":119,"props":257,"children":258},{},[259],{"type":34,"value":260},"Here you will see all the available variations you have for preview including control.",{"type":21,"tag":119,"props":262,"children":263},{},[264],{"type":34,"value":265},"By default, variations are showing randomly but you can force it to display a specific variation by selecting the desired variation from here.",{"type":21,"tag":29,"props":267,"children":269},{"id":268},"notes",[270],{"type":34,"value":271},"Notes",{"type":21,"tag":119,"props":273,"children":274},{},[275],{"type":34,"value":276},"If your test depends on other live/published tests, then ensure those tests are available in the staging mode otherwise the preview links won't work as expected.",{"type":21,"tag":29,"props":278,"children":280},{"id":279},"further