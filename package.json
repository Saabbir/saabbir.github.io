{
  "name": "saabbir.github.io",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Saabbir/saabbir.github.io.git"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "copy:assets": "mkdir -p public && cp -r assets/images public/ 2>/dev/null || true",
    "generate": "npm run copy:assets && nuxt generate && node scripts/generate-sitemap.js",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "deploy": "nuxt generate && push-dir --dir=.output/public --branch=gh-pages --cleanup"
  },
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@nuxt/content": "^2.13.2",
    "@nuxtjs/google-fonts": "^3.2.0",
    "core-js": "^3.36.0",
    "lodash": "^4.17.21",
    "normalize.css": "^8.0.1",
    "nuxt": "^3.14.1593",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "push-dir": "^0.4.1",
    "sass": "^1.80.0",
    "sass-loader": "^16.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
